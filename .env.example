# SCADA Fraccionadora — Variables de Entorno

# ============================================================================
# MOTOR DE CÁLCULO
# ============================================================================

# Motor de cálculo por defecto: python | octave
# python: usa numpy/scipy/cvxpy (siempre disponible)
# octave: usa GNU Octave si está instalado (requiere octave-cli)
CALC_ENGINE=python

# Ruta al binario octave-cli (auto-detect si está en PATH)
# Ej: /usr/bin/octave-cli (Linux)
#     /usr/local/bin/octave (macOS)
OCTAVE_BIN=

# Directorio con scripts .m de Octave
OCTAVE_SCRIPTS_DIR=./backend/octave_scripts

# Timeout para llamadas a Octave [segundos]
OCTAVE_TIMEOUT=30

# ============================================================================
# FASTAPI
# ============================================================================

# Host y puerto del backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Log level
LOG_LEVEL=info

# ============================================================================
# REACT/FRONTEND
# ============================================================================

# URL del backend para conexiones desde frontend
VITE_BACKEND_URL=http://localhost:8000

# Puerto del frontend
FRONTEND_PORT=3000

# ============================================================================
# SIMULACIÓN
# ============================================================================

# Tiempo de muestreo discreto [minutos]
DT_SIMULATION=1.0

# Intervalo de actualización en tiempo real [segundos]
WS_UPDATE_INTERVAL=1.0

# Tamaño del histórico en memoria (puntos)
HISTORY_SIZE=1000

# ============================================================================
# OCTAVE (solo si CALC_ENGINE=octave)
# ============================================================================

# Instalar GNU Octave según tu sistema:
#
# Linux / WSL (Debian/Ubuntu):
#   sudo apt update
#   sudo apt install octave octave-optim octave-signal
#
# macOS (Homebrew):
#   brew install octave
#   # Octave agregará automáticamente los paquetes optim y signal
#
# Windows (Windows Package Manager):
#   winget install GNU.Octave
#   # Después, instala paquetes:
#   octave
#   pkg install -forge optim
#   pkg install -forge signal
#
# Verificar instalación:
#   octave --version
#   octave-cli --version
